{
  "info": {
    "name": "Online-Recuriment-HR API",
    "description": "Aligned with backend /api (same layout as test/Online-Recuriment-HR/postman). Collection variables: baseUrl, demoPassword, email_*, signup_test_email. Login requests save token. Run `npm run db:seed-demo` in backend for hr@demo.local etc. Applicant demo needs DB from init-schema (integer applicant ids); UUID applicant DB: register a new applicant or use an existing applicant email.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "demoPassword", "value": "123456" },
    { "key": "email_superadmin", "value": "superadmin@demo.local" },
    { "key": "email_hr", "value": "hr@demo.local" },
    { "key": "email_interviewer", "value": "interviewer@demo.local" },
    { "key": "email_applicant", "value": "applicant@demo.local" },
    { "key": "signup_test_email", "value": "your.email@gmail.com" },
    { "key": "register_verify_token", "value": "" },
    { "key": "application_id", "value": "1" }
  ],
  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Login Superadmin (staff)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.data && j.data.token) pm.collectionVariables.set('token', j.data.token);",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email_superadmin}}\",\n  \"password\": \"{{demoPassword}}\",\n  \"portal\": \"staff\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login HR (staff)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.data && j.data.token) pm.collectionVariables.set('token', j.data.token);",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email_hr}}\",\n  \"password\": \"{{demoPassword}}\",\n  \"portal\": \"staff\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Interviewer (staff)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.data && j.data.token) pm.collectionVariables.set('token', j.data.token);",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email_interviewer}}\",\n  \"password\": \"{{demoPassword}}\",\n  \"portal\": \"staff\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Applicant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.data && j.data.token) pm.collectionVariables.set('token', j.data.token);",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email_applicant}}\",\n  \"password\": \"{{demoPassword}}\",\n  \"portal\": \"applicant\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login public /login (unified — applicant or staff)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.data && j.data.token) pm.collectionVariables.set('token', j.data.token);",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email_hr}}\",\n  \"password\": \"{{demoPassword}}\",\n  \"portal\": \"unified\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Same as Angular /login — any role. Staff receive JWT and use HR portal; applicant → applicant portal."
          }
        },
        {
          "name": "Auth Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Register applicant — request (Brevo API email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Postman User\",\n  \"email\": \"{{signup_test_email}}\",\n  \"password\": \"{{demoPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register/applicant/request",
            "description": "Requires REQUIRE_EMAIL_VERIFICATION=true and BREVO_API_KEY + BREVO_FROM_EMAIL. Check Gmail for link; token is in URL query verifyToken=."
          }
        },
        {
          "name": "Register applicant — complete (token from email link)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{register_verify_token}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register/applicant/complete",
            "description": "Paste 64-char token from email link into collection variable register_verify_token."
          }
        },
        {
          "name": "Register applicant (direct, no email verify)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Postman User\",\n  \"email\": \"{{signup_test_email}}\",\n  \"password\": \"{{demoPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register/applicant",
            "description": "Works when REQUIRE_EMAIL_VERIFICATION=false."
          }
        },
        {
          "name": "Forgot password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email_hr}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/forgot-password"
          }
        },
        {
          "name": "Reset password (token from email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"paste-reset-token-from-email\",\n  \"newPassword\": \"{{demoPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/reset-password",
            "description": "Token from forgot-password mail (link points to frontend reset-password?token=)."
          }
        },
        {
          "name": "Change password (Bearer token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{demoPassword}}\",\n  \"newPassword\": \"NewPass123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/change-password",
            "description": "Same body as web profile — login first to set token."
          }
        }
      ]
    },
    {
      "name": "02 Public (no token)",
      "item": [
        {
          "name": "Department list",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/department"
          }
        },
        {
          "name": "Vacancy list",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vacancy"
          }
        }
      ]
    },
    {
      "name": "03 Staff (Bearer token)",
      "item": [
        {
          "name": "Applicant list",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/applicant"
          }
        },
        {
          "name": "Application list",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/application"
          }
        },
        {
          "name": "Application by id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/application/{{application_id}}"
          }
        },
        {
          "name": "CV list",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/cv"
          }
        },
        {
          "name": "Audit logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/audit-logs",
            "description": "HR or Superadmin only."
          }
        }
      ]
    }
  ]
}
