PORT=3000

GEMINI_API_KEY_OANHVU=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password
# Use a dedicated DB after importing scripts/backup.sql or init-schema.sql
DB_NAME=online_recruitment
DB_SYNC=false

JWT_SECRET=please-change-this-secret
JWT_EXPIRES_IN=1d
RESET_PASSWORD_EXPIRES_IN=15m
FRONTEND_RESET_PASSWORD_URL=http://localhost:4200/reset-password

BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
# Brevo -> SMTP & API -> SMTP: copy "SMTP login"
BREVO_SMTP_USER=your_brevo_smtp_user
# xsmtpsib key (or leave empty if using BREVO_API_KEY for SMTP; see app.module)
BREVO_SMTP_PASS=your_brevo_smtp_pass
# Verified sender address in Brevo (Senders)
BREVO_FROM_EMAIL=your_verified_sender@example.com
BREVO_FROM_NAME=HR Recruitment
# API v3 key (xkeysib-...) or SMTP key (xsmtpsib-...) - forgot-password and signup emails use BrevoApiService
BREVO_API_KEY=your_brevo_api_key

# true = Gmail verification flow: POST /auth/register/applicant/request + 24h link (keep in sync with requireEmailVerification in Angular).
# false = POST /auth/register/applicant creates account immediately (no verification email).
REQUIRE_EMAIL_VERIFICATION=true

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=your_verified_sender@example.com

APP_PUBLIC_URL=http://localhost:4200
