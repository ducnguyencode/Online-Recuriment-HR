{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "generateOptions": {
    "spec": false,
    "flat": true
  },
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "mail/**/*",
      {
        "include": "services/bullmq/send-mail-worker/templates/**/*.hbs",
        "outDir": "dist"
      }
    ],
    "watchAssets": true
  }
}
